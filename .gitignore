# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/functions/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/release

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# firebase (debug logs can contain deployed secret values — never commit)
firebase-debug.log*
firebase-debug*.log
.firebase/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# supabase cli
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# large OCR language binary (provided by @tesseract.js-data/por; not bundled by electron-builder)
por.traineddata

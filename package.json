{
  "name": "halex-istar-crm",
  "version": "0.2.31",
  "type": "module",
  "description": "Inteligência comercial para hospitais e distribuidores",
  "author": "Daniel Carvalho",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node --test --experimental-strip-types src/**/*.test.ts electron/*.test.cjs",
    "check": "npm run lint && npm run test && npm run build",
    "desktop:web": "next dev -p 3001",
    "desktop:electron": "electron .",
    "desktop:dev": "concurrently -k \"npm:desktop:web\" \"wait-on http://localhost:3001/dashboard && npm run desktop:electron\"",
    "desktop:prepare": "node scripts/prepare-desktop.cjs",
    "build:desktop": "npm run lint && npm run test && node scripts/build-desktop.cjs",
    "desktop:installer": "npm run build:desktop && npm run desktop:prepare && electron-builder --win nsis",
    "desktop:installer:mac": "npm run build:desktop && npm run desktop:prepare && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "desktop:release": "npm run build:desktop && npm run desktop:prepare && node scripts/publish-release.cjs",
    "desktop:release:repair": "node scripts/publish-release.cjs"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/por": "^1.0.0",
    "electron-updater": "^6.8.9",
    "idb": "^7.1.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.3",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.14.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.9",
    "firebase": "^12.16.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    }
  },
  "build": {
    "appId": "br.com.halexistar.crm",
    "productName": "Lumina Prisma",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/app/favicon.ico",
      "artifactName": "Lumina-Prisma-Setup-${version}.${ext}",
      "publish": {
        "provider": "github",
        "owner": "danielcarvalho428-cyber",
        "repo": "halex-istar-crm-releases",
        "releaseType": "release"
      }
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.business",
      "artifactName": "Lumina-Prisma-${version}-${arch}.${ext}",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "title": "Lumina Prisma ${version}",
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "danielcarvalho428-cyber",
      "repo": "halex-istar-crm-releases",
      "releaseType": "release"
    }
  }
}
